# Example environment variables for local development and Vercel
# Copy this file to .env.local (not committed) and fill values in production via Vercel UI

# ===== FIREBASE (Primary Database) =====
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===== APPLICATION URLs =====
NEXT_PUBLIC_BASE_URL=https://your-app-domain.com
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# ===== EMAIL / SMTP =====
SMTP_USER=talent@geonixa.com
SMTP_PASS=iyeh wrhi ccbw pvmi
SMTP_FROM_NAME=Geonixa Talent Acquisition

# ===== ADMIN / REPORTING =====
