# Example environment variables for local development and Vercel deployment
# IMPORTANT: Do NOT commit this file with real credentials to Git
# Copy this file to .env.local (for local development) or set in Vercel UI (for production)
# See: https://nextjs.org/docs/basic-features/environment-variables

# ===== FIREBASE (Primary Database) =====
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN_HERE
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET_HERE
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID_HERE
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID_HERE

# ===== APPLICATION URLs =====
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== EMAIL / SMTP (For sending student credentials and reports) =====
SMTP_USER=YOUR_SMTP_USER_HERE
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_FROM_NAME=YOUR_FROM_NAME_HERE
SMTP_FROM_EMAIL=YOUR_FROM_EMAIL_HERE

# ===== DATABASE =====
MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING_HERE

# ===== SERVER-SIDE FIRESTORE (SECRET: do NOT expose to client) =====
# Get this from Firebase Console > Project Settings > Service Accounts > Generate Private Key
# This is required for server-side Firestore admin operations
FIREBASE_SERVICE_ACCOUNT=YOUR_FIREBASE_SERVICE_ACCOUNT_JSON_HERE

# ===== JWT & SESSION =====
JWT_SECRET=YOUR_STRONG_JWT_SECRET_HERE_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ===== ADMIN / REPORTING =====
ADMIN_REPORT_KEY=YOUR_ADMIN_REPORT_KEY_HERE

# ===== RATE LIMITING =====
RATE_LIMIT_TOKENS=10
RATE_LIMIT_INTERVAL_MS=60000

# ===== CORS =====
ALLOWED_ORIGIN=http://localhost:3000

# ===== API BASE URLS =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
