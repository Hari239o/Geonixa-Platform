rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: The application uses a custom JWT authentication system 
    // and does NOT use Firebase Auth. Therefore, request.auth is always null.
    // To allow the client-side Firebase SDK to work, rules must be open.
    // For a production exam platform, it is HIGHLY recommended to either:
    // 1. Migrate client operations to server-side API routes using Firebase Admin SDK.
    // 2. Or integrate Firebase Auth (e.g., custom tokens) to securely enforce rules.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}