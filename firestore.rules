rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // STUDENTS COLLECTION - Basic profile data
    match /students/{userId} {
      // Allow read/write for authenticated users to their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow admin read access
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // EXAM RESULTS COLLECTION - Overall exam results
    match /examResults/{resultId} {
      // Students can only read their own results
      allow read: if request.auth != null &&
        resource.data.studentId == request.auth.uid;

      // Students can create/update their own results during exam
      allow create, update: if request.auth != null &&
        request.auth.uid == resource.data.studentId;

      // Admin full access
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ROUND RESULTS COLLECTION - Detailed round-wise results
    match /roundResults/{resultId} {
      // Students can only read their own results
      allow read: if request.auth != null &&
        resource.data.studentId == request.auth.uid;

      // Students can create/update their own results during exam
      allow create, update: if request.auth != null &&
        request.auth.uid == resource.data.studentId;

      // Admin full access
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // CODING SUBMISSIONS COLLECTION - Individual coding question submissions
    match /codingSubmissions/{submissionId} {
      // Students can only read their own submissions
      allow read: if request.auth != null &&
        resource.data.studentId == request.auth.uid;

      // Students can create/update their own submissions during exam
      allow create, update: if request.auth != null &&
        request.auth.uid == resource.data.studentId;

      // Admin full access
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // MCQ RESPONSES COLLECTION - Individual MCQ responses
    match /mcqResponses/{responseId} {
      // Students can only read their own responses
      allow read: if request.auth != null &&
        resource.data.studentId == request.auth.uid;

      // Students can create/update their own responses during exam
      allow create, update: if request.auth != null &&
        request.auth.uid == resource.data.studentId;

      // Admin full access
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // PROCTORING LOGS COLLECTION - AI proctoring events
    match /proctoringLogs/{logId} {
      // Students cannot read proctoring logs (privacy)
      allow read: if false;

      // Students can create logs during exam (for violation reporting)
      allow create: if request.auth != null;

      // Admin full access
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // LEGACY COLLECTIONS - For backward compatibility
    match /exam_submissions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /student_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /valid_logins/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // META COLLECTION - System configuration
    match /meta/{document} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // EMAIL LOGS COLLECTION - Communication tracking
    match /email_logs/{logId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS COLLECTION - Admin user management
    match /users/{userId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}